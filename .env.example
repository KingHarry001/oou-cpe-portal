# Copy to .env and fill in your Supabase project values.
# The anon key is safe to expose in the client bundle; never put the service_role key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Dev-only: set to "true" to run against in-memory mock data (src/lib/mockSupabase.js)
# instead of a live Supabase project. Ignored in production builds. Use the
# hidden /dev/student, /dev/lecturer, /dev/admin routes to sign in.
VITE_USE_MOCK=false
